# AccountBuddy 环境配置
# 复制此文件为 .env 并修改配置

# SQLite 数据库路径（不设置 Supabase 时使用）
DB_PATH=/home/admin/projects/AccountBuddy/data/accountbuddy.sqlite

# Supabase 云数据库（设置后后端会优先使用 Supabase）
# SUPABASE_PROJECT_ID=kayflowsmvhbbptcluos
# SUPABASE_URL=https://kayflowsmvhbbptcluos.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# 推荐服务端部署时使用 service role key，避免公开表权限；不要把 service role key 放进前端。
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 前端部署到 Netlify、后端部署到 Render/Railway/Fly 等平台时设置
# VITE_API_BASE_URL=https://your-api.example.com

# 服务器端口（建议保持 3001，通过 Nginx 反向代理暴露）
PORT=3001

# 环境模式
NODE_ENV=production

# 允许的主机（用于 CORS，多个用逗号分隔）
# 生产环境建议设置为具体域名
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 速率限制配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# 日志级别（debug, info, warn, error）
LOG_LEVEL=info

# 会话密钥（用于签名，请生成随机字符串）
# SESSION_SECRET=your-random-secret-key-here
