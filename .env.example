# AccountBuddy 环境配置
# 复制此文件为 .env 并修改配置

# SQLite 数据库路径（仅 legacy Express 后端和迁移脚本使用）
DB_PATH=/home/admin/projects/AccountBuddy/data/accountbuddy.sqlite

# Supabase 云数据库
# SUPABASE_PROJECT_ID=kayflowsmvhbbptcluos
# SUPABASE_URL=https://kayflowsmvhbbptcluos.supabase.co
# 仅迁移/创建 Auth 用户脚本需要 service role key。不要放进 Netlify 前端变量。
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 前端直连 Supabase。Netlify 也填这三个 VITE_ 变量。
# VITE_SUPABASE_URL=https://kayflowsmvhbbptcluos.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# VITE_SUPABASE_LOGIN_DOMAIN=account-buddy.local

# 创建 Supabase Auth 用户脚本使用。
# 默认用户名 house 会映射到 house@account-buddy.local。
# AUTH_EMAIL=house@account-buddy.local
# AUTH_PASSWORD=260321

# Legacy Express 后端配置（纯 Netlify + Supabase 部署不需要）
PORT=3001

# 环境模式
NODE_ENV=production

# 允许的主机（用于 CORS，多个用逗号分隔）
# 生产环境建议设置为具体域名
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 速率限制配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# 日志级别（debug, info, warn, error）
LOG_LEVEL=info

# 会话密钥（用于签名，请生成随机字符串）
# SESSION_SECRET=your-random-secret-key-here
