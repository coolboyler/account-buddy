# AccountBuddy Nginx 配置
# 将此文件复制到 /etc/nginx/conf.d/ 并修改 server_name

upstream accountbuddy {
    server 127.0.0.1:3001;
    keepalive 32;
}

# 速率限制区域
limit_req_zone $binary_remote_addr zone=accountbuddy_limit:10m rate=10r/s;
limit_conn_zone $binary_remote_addr zone=accountbuddy_conn:10m;

server {
    listen 80;
    server_name _;  # 修改为实际域名或使用 localhost

    # 安全响应头
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # 限制请求体大小
    client_max_body_size 10k;

    # 速率限制
    limit_req zone=accountbuddy_limit burst=20 nodelay;
    limit_conn accountbuddy_conn 10;

    # 日志配置
    access_log /var/log/nginx/accountbuddy_access.log;
    error_log /var/log/nginx/accountbuddy_error.log;

    location / {
        proxy_pass http://accountbuddy;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        
        # 代理超时设置
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # 静态文件缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg)$ {
        proxy_pass http://accountbuddy;
        expires 1d;
        add_header Cache-Control "public, immutable";
    }
}

# HTTPS 配置（如果有证书）
# server {
#     listen 443 ssl http2;
#     server_name your-domain.com;
#
#     ssl_certificate /path/to/cert.pem;
#     ssl_certificate_key /path/to/key.pem;
#     ssl_protocols TLSv1.2 TLSv1.3;
#     ssl_ciphers HIGH:!aNULL:!MD5;
#     ssl_prefer_server_ciphers on;
#
#     # 其他配置同上
# }
